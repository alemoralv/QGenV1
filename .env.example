# Copy to ".env" in the project root and fill in at least one provider.

# Primary: OpenAI (used when this value is non-empty)
OPENAI_API_KEY=

# Fallback: Google Gemini API (used when OPENAI_API_KEY is empty)
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# If you use Google's GEMINI_API_KEY name instead, set in config.yaml:
#   google_api_key_env: GEMINI_API_KEY
